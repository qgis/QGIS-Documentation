#: ../../docs/user_manual/processing_algs/qgis/modelertools.rst:2
msgid "Modeler tools"
msgstr "Modeliuotojo įrankiai"

#: ../../docs/user_manual/processing_algs/qgis/modelertools.rst:6
msgid ""
