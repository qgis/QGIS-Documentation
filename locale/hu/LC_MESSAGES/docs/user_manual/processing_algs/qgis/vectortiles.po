#: ../../docs/user_manual/processing_algs/qgis/vectortiles.rst:256
msgid ""
"The lowest zoom level for which the tileset provides data. Set between 0 and"
" 24."
msgstr ""
"A legalacsonyabb nagyítási szint, amelyen a csempekészlet adatokat "
"szolgáltat. Állítsa 0 és 24 közé."

#: ../../docs/user_manual/processing_algs/qgis/vectortiles.rst:129
#: ../../docs/user_manual/processing_algs/qgis/vectortiles.rst:258
msgid "**Maximum zoom level**"
msgstr "**Maximum nagyítási szint**"

#: ../../docs/user_manual/processing_algs/qgis/vectortiles.rst:133
#: ../../docs/user_manual/processing_algs/qgis/vectortiles.rst:262
