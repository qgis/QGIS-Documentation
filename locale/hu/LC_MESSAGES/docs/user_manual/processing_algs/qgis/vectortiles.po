msgid "Defines how far to zoom in and fetch data from the tiles"
msgstr ""
"Meghatározza, hogy meddig nagyítson bele és kérjen le adatokat a csempékből"

#: ../../docs/user_manual/processing_algs/qgis/vectortiles.rst:51
msgid "**Tile limit**"
msgstr "**Csempekorlát**"

#: ../../docs/user_manual/processing_algs/qgis/vectortiles.rst:52
msgid "``TILE_LIMIT``"
msgstr "``TILE_LIMIT``"

#: ../../docs/user_manual/processing_algs/qgis/vectortiles.rst:55
msgid "Default: 100"
msgstr "Alapértelmezett: 100"

#: ../../docs/user_manual/processing_algs/qgis/vectortiles.rst:56
msgid ""
"Maximum number of tiles to download, considering the zoom levels and the "
"extent."
msgstr ""
"A letöltendő csempék maximális száma, figyelembe véve a nagyítási szinteket "
"és a terjedelmet."

