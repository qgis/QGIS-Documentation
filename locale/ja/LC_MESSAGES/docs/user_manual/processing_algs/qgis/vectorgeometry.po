msgstr "**最大値**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:3027
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:3130
msgid "``MAX``"
msgstr "``MAX``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:3031
msgid "Maximum of M values allowed"
msgstr "M値の上限値"

