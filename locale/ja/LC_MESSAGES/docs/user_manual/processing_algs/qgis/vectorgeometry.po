msgstr ":ref:`qgisbufferbym` 、 :ref:`qgisbuffer` 、 :ref:`qgiswedgebuffers`"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7019
msgid "**Start width**"
msgstr "**始点における直径**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7020
msgid "``START_WIDTH``"
msgstr "``START_WIDTH``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7024
msgid ""
"Represents the radius of the buffer applied at the start point of the line "
"feature"
msgstr "ライン地物の始点におけるバッファの直径"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7026
msgid "**End width**"
msgstr "**終点における直径**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7027
msgid "``END_WIDTH``"
msgstr "``END_WIDTH``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7031
msgid ""
"Represents the radius of the buffer applied at the end point of the line "
"feature."
msgstr "ライン地物の終点におけるバッファの直径"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7037
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7393
msgid "Default: 16"
msgstr "デフォルト： 16"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7072
