#: ../../docs/user_manual/processing_algs/qgis/vectortable.rst:749
#: ../../docs/user_manual/processing_algs/qgis/vectortable.rst:862
msgid "[expression]"
msgstr "[uttryck]"

#: ../../docs/user_manual/processing_algs/qgis/vectortable.rst:80
msgid ""
"Use an expression to sort the features in the layer either globally or if "
"set, based on group fields."
msgstr ""
"Använd ett uttryck för att sortera objekten i lagret antingen globalt eller,"
" om det är inställt, baserat på gruppfält."

#: ../../docs/user_manual/processing_algs/qgis/vectortable.rst:82
msgid "**Sort ascending**"
msgstr "**Sortera stigande**"

#: ../../docs/user_manual/processing_algs/qgis/vectortable.rst:83
msgid "``SORT_ASCENDING``"
msgstr "``SORT_ASCENDING``"

