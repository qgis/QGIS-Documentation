msgstr ""
"Skapar ett polygonlager med Delaunay-triangulering som motsvarar det "
"inmatade punktlagret."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1641
msgid "Delaunay triangulation on points"
msgstr "Delaunay-triangulering på punkter"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1661
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:4858
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5356
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6216
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6544
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7478
msgid "**Tolerance**"
msgstr "**Tolerans**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1664
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:4859
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5357
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6217
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6545
