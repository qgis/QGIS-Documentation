#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:2607
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3323
msgid "``CRS``"
msgstr "``CRS``"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:2473
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:2609
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3325
