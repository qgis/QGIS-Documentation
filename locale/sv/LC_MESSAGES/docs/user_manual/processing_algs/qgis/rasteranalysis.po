msgid "The layer to rank the values among the stack of all overlaid layers"
msgstr ""
"Det lager som ska rangordna värdena bland stapeln av alla överlagrade lager"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:23
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:431
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:784
msgid "**Value raster band**"
msgstr "**Värde rasterband**"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:432
msgid "``VALUE_RASTER_BAND``"
msgstr "``VALUE_RASTER_BAND``"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:435
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3167
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3669
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3961
