msgid "Field containing the temporal information"
msgstr "Fält som innehåller den temporala informationen"

#: ../../docs/user_manual/processing_algs/qgis/vectoranalysis.rst:1622
msgid "**Maximum time duration between clustered points**"
msgstr "**Maximal tidslängd mellan klustrade punkter**"

#: ../../docs/user_manual/processing_algs/qgis/vectoranalysis.rst:1623
msgid "``EPS2``"
msgstr "``EPS2``"

#: ../../docs/user_manual/processing_algs/qgis/vectoranalysis.rst:1626
msgid "Default: 0.0 (days)"
msgstr "Standard: 0,0 (dagar)"

#: ../../docs/user_manual/processing_algs/qgis/vectoranalysis.rst:1627
msgid ""
"Time duration beyond which two features can not belong to the same cluster "
"(eps2). Available time units are milliseconds, seconds, minutes, hours, days"
" and weeks."
msgstr ""
"Tidsperiod efter vilken två funktioner inte kan tillhöra samma kluster "
"(eps2). Tillgängliga tidsenheter är millisekunder, sekunder, minuter, "
"timmar, dagar och veckor."

