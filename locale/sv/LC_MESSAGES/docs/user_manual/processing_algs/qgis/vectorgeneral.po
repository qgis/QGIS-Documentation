msgid "**Output layer**"
msgstr "**Utmatningslager**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:2566
msgid "Input vector layer with the set encoding."
msgstr "Ingångsvektorlager med den inställda kodningen."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:2571
