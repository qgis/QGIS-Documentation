msgid "Introducing GIS"
msgstr "Prezentare GIS"

#: ../../docs/gentle_gis_introduction/introducing_gis.rst:7
msgid "|gentleLogo|"
msgstr "|gentleLogo|"

#: ../../docs/gentle_gis_introduction/introducing_gis.rst:364
