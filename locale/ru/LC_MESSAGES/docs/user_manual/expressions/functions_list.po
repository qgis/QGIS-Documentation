#: ../../docs/user_manual/expressions/expression_help/Aggregates.rst:56
msgid ""
"``aggregate(layer:='rail_stations',aggregate:='sum',expression:=\"passengers\")``"
" → sum of all values from the passengers field in the rail_stations layer"
msgstr ""
"``aggregate(layer:='rail_stations',aggregate:='sum',expression:=\"passengers\")``"
" → сумма всех значений из поля пассажиров в слое rail_stations"

#: ../../docs/user_manual/expressions/expression_help/Aggregates.rst:57
msgid ""
"``aggregate('rail_stations','sum', \"passengers\"/7)`` → calculates a daily "
"average of \"passengers\" by dividing the \"passengers\" field by 7 before "
"summing the values"
msgstr ""
"``aggregate('rail_stations','sum', \"passengers\"/7)`` → вычисляет "
"среднесуточное значение «passengers», деля поле «passengers» на 7 перед "
"суммированием значений."

#: ../../docs/user_manual/expressions/expression_help/Aggregates.rst:58
msgid ""
"``aggregate(layer:='rail_stations',aggregate:='sum',expression:=\"passengers\",filter:=\"class\">3)``"
" → sums up all values from the \"passengers\" field from features where the "
"\"class\" attribute is greater than 3 only"
msgstr ""
"``aggregate(layer:='rail_stations',aggregate:='sum',expression:=\"passengers\",filter:=\"class\">3)``"
" → суммирует все значения из поля «passengers» только из объектов, у которых"
" атрибут «class» больше 3."

#: ../../docs/user_manual/expressions/expression_help/Aggregates.rst:59
msgid ""
"``aggregate(layer:='rail_stations',aggregate:='concatenate', "
"expression:=\"name\", concatenator:=',')`` → comma separated list of the "
"name field for all features in the rail_stations layer"
msgstr ""
"``aggregate(layer:='rail_stations',aggregate:='concatenate', "
"expression:=\"name\", concatenator:=',')`` → список полей name для всех "
"объектов в слое rail_stations, разделенный запятыми"

#: ../../docs/user_manual/expressions/expression_help/Aggregates.rst:60
msgid ""
"``aggregate(layer:='countries', aggregate:='max', expression:=\"code\", "
"filter:=intersects( @geometry, geometry(@parent) ) )`` → The country code of"
" an intersecting country on the layer 'countries'"
msgstr ""
"``aggregate(layer:='countries', aggregate:='max', expression:=\"code\", "
"filter:=intersects( @geometry, geometry(@parent) ) )`` → Код страны, "
"пересекающейся со слоем «countries»"

#: ../../docs/user_manual/expressions/expression_help/Aggregates.rst:61
msgid ""
"``aggregate(layer:='rail_stations',aggregate:='sum',expression:=\"passengers\",filter:=contains("
" @atlas_geometry, @geometry ) )`` → sum of all values from the passengers "
"field in the rail_stations within the current atlas feature"
msgstr ""
"``aggregate(layer:='rail_stations',aggregate:='sum',expression:=\"passengers\",filter:=contains("
" @atlas_geometry, @geometry ) )`` → сумма всех значений из поля пассажиров в"
" rail_stations в пределах текущего объекта атласа"

#: ../../docs/user_manual/expressions/expression_help/Aggregates.rst:62
msgid ""
"``aggregate(layer:='rail_stations', aggregate:='collect', "
"expression:=centroid(@geometry), filter:=\"region_name\" = "
"attribute(@parent,'name') )`` → aggregates centroid geometries of the "
"rail_stations of the same region as current feature"
msgstr ""
"``aggregate(layer:='rail_stations', aggregate:='collect', "
"expression:=centroid(@geometry), filter:=\"region_name\" = "
"attribute(@parent,'name') )`` → агрегирует геометрии центроидов "
"железнодорожных станций того же региона, что и текущий объект"

#: ../../docs/user_manual/expressions/expression_help/Aggregates.rst:70
msgid "array_agg"
msgstr "array_agg"

#: ../../docs/user_manual/expressions/expression_help/Aggregates.rst:72
msgid "Returns an array of aggregated values from a field or expression."
msgstr "Возвращает массив агрегированных значений из поля или выражения."

#: ../../docs/user_manual/expressions/expression_help/Aggregates.rst:78
msgid "array_agg(expression, [group_by], [filter], [order_by])"
msgstr "array_agg(expression, [group_by], [filter], [order_by])"

