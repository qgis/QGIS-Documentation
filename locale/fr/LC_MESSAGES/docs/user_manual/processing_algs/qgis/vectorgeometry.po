msgstr "``ROTATION``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5271
msgid "Rotation of the buffer shape"
msgstr "Rotation de la forme du buffer"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5272
