msgid "Input vector layer (with non-NULL geometries)"
msgstr "Couche vectorielle en entrée (avec des géométries non NULL)"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5449
msgid "**Also remove empty geometries**"
msgstr "**Egalement supprimer les géométries vides**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5450
