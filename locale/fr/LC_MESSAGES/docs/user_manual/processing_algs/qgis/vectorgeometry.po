msgstr ""
"**Angle en degrés par rapport à la ligne d'origine au niveau des sommet**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7214
msgid "Default: 90.0"
msgstr "Par défaut : 90.0"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7215
