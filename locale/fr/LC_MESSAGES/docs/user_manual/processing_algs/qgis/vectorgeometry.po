#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6973
msgid "**Swapped**"
msgstr "**Échangé**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6976
msgid "Output (swapped) vector layer"
msgstr "Couche vectorielle de sortie (permutée)"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6981
msgid "**Algorithm ID**: ``native:swapxy``"
msgstr "**ID de l'algorithme** : ``native:swapxy``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6991
msgid "Tapered buffers"
msgstr "Tampons coniques"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6992
msgid ""
"Creates tapered buffer along line geometries, using a specified start and "
