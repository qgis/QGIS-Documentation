#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:3132
msgid "Minimum of Z values allowed"
msgstr "Minimum de valeurs Z autorisées"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:3140
msgid "Maximum of Z values allowed"
msgstr "Maximum de valeurs Z autorisées"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:3173
