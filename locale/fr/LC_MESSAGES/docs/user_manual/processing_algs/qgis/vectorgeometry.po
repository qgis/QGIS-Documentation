msgstr "Par défaut : '0'"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2719
msgid "Comma-separated string of the indices of the vertices to extract."
msgstr "Chaîne séparée par des virgules des indices des vertex à extraire."

