#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7157
msgid "Transect"
msgstr "Transect "

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7158
msgid "Creates transects on vertices for (multi)linestring."
msgstr "Crée des transects sur les sommets pour les (multi)ligne."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7160
msgid ""
"A transect is a line oriented from an angle (by default perpendicular) to "
"the input polylines (at vertices)."
msgstr ""
"Un transect est une ligne orientée d'un angle (par défaut perpendiculaire) "
"aux polylignes d'entrée (aux sommets)."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7163
msgid ""
"Field(s) from feature(s) are returned in the transect with these new fields:"
msgstr ""
"Les champs des entités sont retournés dans le transect avec ces nouveaux "
"champs:"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7166
msgid "TR_FID: ID of the original feature"
msgstr "TR_FID: ID de l'entité d'origine"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7167
msgid "TR_ID: ID of the transect. Each transect have an unique ID"
msgstr "TR_ID: ID du transect. Chaque transect a un identifiant unique"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7168
msgid "TR_SEGMENT: ID of the segment of the linestring"
msgstr "TR_SEGMENT: ID du segment de la  ligne"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7169
msgid "TR_ANGLE: Angle in degrees from the original line at the vertex"
msgstr "TR_ANGLE: Angle en degrés par rapport à la ligne d'origine au sommet"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7170
msgid "TR_LENGTH: Total length of the transect returned"
msgstr "TR_LENGTH: longueur totale du transect retourné"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7171
msgid ""
"TR_ORIENT: Side of the transect (only on the left or right of the line, or "
"both side)"
msgstr ""
"TR_ORIENT: Côté du transect (uniquement à gauche ou à droite de la ligne, ou"
" les deux côtés)"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7180
msgid "Dashed red lines represent the transect of the input line layer"
msgstr ""
"Les lignes rouges en pointillés représentent le transect de la couche de "
"ligne d'entrée"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7198
msgid "**Length of the transect**"
msgstr "**Longueur du transect**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7203
msgid "Length in map unit of the transect"
msgstr "Longueur en unité de carte du transect"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7204
msgid "**Angle in degrees from the original line at the vertices**"
msgstr ""
"**Angle en degrés par rapport à la ligne d'origine au niveau des sommet**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7208
msgid "Default: 90.0"
msgstr "Par défaut : 90.0"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7209
msgid "Change the angle of the transect"
msgstr "Changer l'angle du transect"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7210
