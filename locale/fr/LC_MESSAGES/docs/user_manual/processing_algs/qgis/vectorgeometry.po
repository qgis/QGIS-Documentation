msgstr "**Nombre maximal de nœuds en parties**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6875
msgid "``MAX_NODES``"
msgstr "``MAX_NODES``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6878
msgid "Default: 256"
msgstr "Par défaut : 256"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6879
msgid ""
"Maximum number of vertices each new geometry part is allowed to have. Fewer "
"*sub-parts* for higher values."
msgstr ""
"Nombre maximal de sommets que chaque nouvelle partie géométrique peut avoir."
" Moins de *sous-parties* pour des valeurs plus élevées."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6882
