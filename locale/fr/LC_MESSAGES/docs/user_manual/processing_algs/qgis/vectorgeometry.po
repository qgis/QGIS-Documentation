msgstr "Couche vectorielle de sortie (permutée)"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6987
msgid "**Algorithm ID**: ``native:swapxy``"
msgstr "**ID de l'algorithme** : ``native:swapxy``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6997
msgid "Tapered buffers"
msgstr "Tampons coniques"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6998
