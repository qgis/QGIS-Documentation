msgstr "La bande raster dont les valeurs M sont tirées"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6075
msgid "The output vector layer (with updated M values)"
msgstr "La couche vectorielle de sortie (avec les valeurs M mises à jour)"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6080
