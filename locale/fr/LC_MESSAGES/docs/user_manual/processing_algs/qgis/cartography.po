msgid "[layer]"
msgstr "[couche]"

#: ../../docs/user_manual/processing_algs/qgis/cartography.rst:1460
msgid "Input layer you want to apply the style to"
msgstr "Couche d'entrée à laquelle vous voulez appliquer le style"

