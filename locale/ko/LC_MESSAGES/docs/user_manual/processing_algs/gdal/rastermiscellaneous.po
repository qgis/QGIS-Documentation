#: ../../docs/user_manual/processing_algs/gdal/rastermiscellaneous.rst:1465
msgid "0 -- Auto (``AUTO``)"
msgstr "0 -- 자동 (``AUTO``)"

#: ../../docs/user_manual/processing_algs/gdal/rastermiscellaneous.rst:1466
msgid "1 -- Well-known text (``WKT``)"
msgstr "1 -- Well-known text (``WKT``)"

#: ../../docs/user_manual/processing_algs/gdal/rastermiscellaneous.rst:1467
msgid "2 -- EPSG (``EPSG``)"
msgstr "2 -- EPSG (``EPSG``)"

