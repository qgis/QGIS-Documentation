msgid "Method to apply to the small polygon geometries:"
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/fixgeometry.rst:1197
msgid ""
"0 --- ``Merge with neighboring polygon with longest shared edge``: merges"
" the small polygon geometry with the neighboring polygon that has the "
"longest shared edge."
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/fixgeometry.rst:1199
msgid ""
"1 --- ``Merge with neighboring polygon with largest area``: merges the "
"small polygon geometry with the neighboring polygon that has the largest "
"area."
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/fixgeometry.rst:1201
msgid ""
"2 --- ``Merge with neighboring polygon with identical attribute value, if"
" any, or leave as is``: merges the small polygon geometry with a "
"neighboring polygon that has the same attribute value, if such a polygon "
"exists."
msgstr ""

