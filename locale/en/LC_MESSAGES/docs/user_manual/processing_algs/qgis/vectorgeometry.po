msgid "**Vertex indices**"
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2724
msgid "Default: '0'"
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2725
msgid "Comma-separated string of the indices of the vertices to extract."
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2727
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2750
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2824
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2847
msgid "**Vertices**"
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2753
msgid ""
"The output (point) vector layer containing the specified vertices from "
"the input layer geometries. Other than the input attributes, the output "
"layer also contains the following fields:"
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2757
msgid ""
"``vertex_pos``: the index of the vertex in the geometry, as requested by "
"the user."
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2758
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2854
msgid ""
"``vertex_index``: the index of the vertex within the geometry. The first "
"vertex is indexed as 0."
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2759
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2855
msgid ""
"``vertex_part``: the part number of the geometry that the vertex belongs "
"to. For single-part geometries, this is always 0. For multi-part "
"geometries (e.g. MultiPolygon or MultiLine), this indicates which part "
"the vertex comes from."
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2761
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2857
msgid ""
"``vertex_part_ring``: for polygon geometries, this indicates whether the "
"vertex belongs to the outer ring (0) or one of the inner rings (1, 2, "
"...)."
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2762
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2858
msgid ""
"``vertex_part_index``: the index of the vertex in its specific ring "
"(outer or inner)."
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2763
msgid ""
"``distance``: the cumulative length of line segments from the first "
"vertex of the geometry."
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2764
msgid ""
"``angle``: the angle (in degrees) between the previous and the current "
"vertex."
msgstr ""

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2769
msgid "**Algorithm ID**: ``native:extractspecificvertices``"
msgstr ""

