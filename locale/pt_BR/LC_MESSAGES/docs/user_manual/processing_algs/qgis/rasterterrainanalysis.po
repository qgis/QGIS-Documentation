msgid "Azimuth and vertical angle"
msgstr "Azimute e ângulo vertical"

#: ../../docs/user_manual/processing_algs/qgis/rasterterrainanalysis.rst:485
msgid "**Azimuth (horizontal angle)**"
msgstr "**Azimute (ângulo horizontal)**"

