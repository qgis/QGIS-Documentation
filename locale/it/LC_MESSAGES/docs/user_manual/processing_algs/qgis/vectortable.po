#: ../../docs/user_manual/processing_algs/qgis/vectortable.rst:71
msgid ""
"Select grouping field(s): instead of a single count run for the whole layer,"
" a separate count is processed for each value returned by the combination of"
" these fields."
msgstr ""
"Selezionare campo(i) di raggruppamento: invece di un unico conteggio per "
"l'intero layer, viene elaborato un conteggio separato per ogni valore "
"restituito dalla combinazione di questi campi."

#: ../../docs/user_manual/processing_algs/qgis/vectortable.rst:75
msgid "**Sort expression**"
msgstr "**Espressione di ordinamento**"

#: ../../docs/user_manual/processing_algs/qgis/vectortable.rst:78
msgid "``SORT_EXPRESSION``"
msgstr "``SORT_EXPRESSION``"

