msgid "``OUTER_RADIUS``"
msgstr "``OUTER_RADIUS``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1581
msgid ""
"The outer *size* (length) of the wedge: the size is meant from the source "
"point to the edge of the wedge shape."
msgstr ""
"La *dimensione* esterna (lunghezza) dello spicchio: la dimensione è intesa "
"dal punto di origine al margine della forma dello spicchio."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1584
msgid "**Inner radius**"
msgstr "**Raggio interno**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1586
