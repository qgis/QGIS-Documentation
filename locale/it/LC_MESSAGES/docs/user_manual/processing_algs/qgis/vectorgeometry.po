msgid "**Rotation (degrees clockwise)**"
msgstr "**Rotazione (gradi in senso orario)**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5611
msgid "Angle of the rotation in degrees"
msgstr "Angolo di rotazione in gradi"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5612
msgid "**Rotation anchor point (x, y)**"
msgstr "**Punto di ancoraggio della rotazione (x, y)**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5615
msgid "``ANCHOR``"
msgstr "``ANCHOR``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5616
msgid "[coordinates]"
msgstr "[coordinates]"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5619
msgid ""
"X,Y coordinates of the point to rotate the features around. If not set the "
"rotation occurs around each feature's centroid."
msgstr ""
"Coordinate X,Y del punto attorno al quale ruotare gli elementi. Se non è "
"impostato, la rotazione avviene intorno al centroide di ogni elemento."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5623
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5647
msgid "**Rotated**"
msgstr "**Ruotato**"

