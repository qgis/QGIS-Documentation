msgstr "0 --- Sinistro"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7315
msgid "1 --- Right"
msgstr "1 --- Destro"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7316
msgid "2 --- Both"
msgstr "2 --- Entrambi"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7318
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7342
msgid "**Transect**"
msgstr "**Transetto**"

