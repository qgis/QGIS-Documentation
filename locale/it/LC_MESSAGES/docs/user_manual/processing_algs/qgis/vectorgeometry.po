msgid ""
"Specify the output vector layer (with Z values from the raster layer). "
":ref:`One of <output_parameter_widget>`:"
msgstr ""
"Specifica il layer vettoriale in uscita (con valori Z dal layer raster). "
":ref:`One of <output_parameter_widget>`:"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2316
msgid "The output vector layer with Z values from the raster layer"
msgstr "Il layer vettoriale in uscita con i valori Z del layer raster"

