msgstr "**ID Algoritmo**: ``native:transect``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7360
msgid "Translate"
msgstr "Trasla"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7361
msgid ""
"Moves the geometries within a layer, by offsetting with a predefined X and Y"
" displacement."
msgstr ""
"Sposta le geometrie di un layer, con uno spostamento di offset X e Y "
"prestabilito."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7364
msgid "Z and M values present in the geometry can also be translated."
msgstr ""
