msgid "Optional"
msgstr "Opzionale"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1587
msgid "``INNER_RADIUS``"
msgstr "``INNER_RADIUS``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1591
msgid "Inner radius value. If 0 the wedge will begin from the source point."
msgstr ""
"Valore del raggio interno. Se 0 lo spicchio inizierà dal punto di origine."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1593
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1616
msgid "**Buffers**"
msgstr "**Buffer**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1619
msgid "The output (wedge buffer) vector layer"
msgstr "Il layer vettoriale in uscita (buffer a spicchio)"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1624
