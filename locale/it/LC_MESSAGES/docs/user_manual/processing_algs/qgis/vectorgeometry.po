msgstr "Mosaicatura"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7182
msgid ""
"Tessellates a polygon geometry layer, dividing the geometries into "
"triangular components."
msgstr "Tassella un vettore poligonale, dividendo le geometrie in triangoli."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7185
msgid ""
"The output layer consists of multipolygon geometries for each input feature,"
" with each multipolygon consisting of multiple triangle component polygons."
msgstr ""
"Il risultato consiste in geometrie multipoligonali per ogni elemento in "
"ingresso, con ogni multi poligono costituito da poligoni triangolari."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7192
msgid "Tessellated polygon (right)"
msgstr "Poligono tassellato (destra)"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7241
