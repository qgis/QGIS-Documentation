#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5470
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5493
msgid "**Cleaned**"
msgstr "**Pulito**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1890
