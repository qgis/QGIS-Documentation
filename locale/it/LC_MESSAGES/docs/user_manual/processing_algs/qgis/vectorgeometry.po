msgstr "0 --- Area più grande"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2349
msgid "1 --- Smallest Area"
msgstr "1 --- Area più piccola"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2350
