#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7256
msgid "Transect"
msgstr "Transetto"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7257
msgid "Creates transects on vertices for (multi)linestring."
msgstr "Crea transetti sui vertici per (multi)linee."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7259
msgid ""
"A transect is a line oriented from an angle (by default perpendicular) to "
"the input polylines (at vertices)."
msgstr ""
"Un transetto è una linea orientata da un angolo (predefinito: "
"perpendicolare) ad una polilinea in ingresso (ai vertici)."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7262
msgid ""
"Field(s) from feature(s) are returned in the transect with these new fields:"
msgstr ""
"Il campo(i) dell'elemento(i) sono restituiti nel transetto con questi nuovi "
"campi:"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7265
msgid "TR_FID: ID of the original feature"
msgstr "TR_FID: ID dell'elemento originale"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7266
msgid "TR_ID: ID of the transect. Each transect have an unique ID"
msgstr "TR_ID: ID del transetto. Ogni transetto ha un ID univoco"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7267
msgid "TR_SEGMENT: ID of the segment of the linestring"
msgstr "TR_SEGMENT: ID del segmento della linea"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7268
msgid "TR_ANGLE: Angle in degrees from the original line at the vertex"
msgstr "TR_ANGLE: Angolo in gradi dalla linea originale al vertice"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7269
msgid "TR_LENGTH: Total length of the transect returned"
msgstr "TR_LENGTH: Lunghezza totale del transetto"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7270
msgid ""
"TR_ORIENT: Side of the transect (only on the left or right of the line, or "
"both side)"
msgstr ""
"TR_ORIENT: Lato del transetto (solamente a sinistra o a destra della linea, "
"o entrambi i lati)"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7279
msgid "Dashed red lines represent the transect of the input line layer"
msgstr ""
"La linea rossa tratteggiata rappresenta il transetto del vettore lineare in "
"ingresso."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7297
msgid "**Length of the transect**"
msgstr "**Lunghezza del transetto**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7302
msgid "Length in map unit of the transect"
msgstr "Lunghezza in unità di mappa del transetto"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7303
msgid "**Angle in degrees from the original line at the vertices**"
msgstr "**Angolo in gradi dalla linea originale ai vertici**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7307
msgid "Default: 90.0"
msgstr "Predefinito: 90.0"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7308
msgid "Change the angle of the transect"
msgstr "Cambiare l'angolo del transetto"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7309
msgid "**Side to create the transect**"
msgstr "**Lato per creare il transetto**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:7312
