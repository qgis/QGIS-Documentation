#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:3945
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5260
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5450
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5464
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5614
