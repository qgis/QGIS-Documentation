msgid ""
"Specify the output slope raster layer. :ref:`One of "
"<output_parameter_widget>`:"
msgstr ""
"Specifica il layer raster delle pendenze in uscita. :ref:`One of "
"<output_parameter_widget>`:"

#: ../../docs/user_manual/processing_algs/qgis/rasterterrainanalysis.rst:910
msgid "The output slope raster layer"
msgstr "Il layer raster della pendenza in uscita"
