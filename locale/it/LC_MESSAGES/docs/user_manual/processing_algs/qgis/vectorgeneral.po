msgid "1 --- contain"
msgstr "1 --- contiene"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:1655
#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:1822
msgid "2 --- equal"
msgstr "2 --- uguale"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:1656
#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:1823
msgid "3 --- touch"
msgstr "3 --- tocca"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:1657
#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:1824
msgid "4 --- overlap"
msgstr "4 --- sovrapposizione"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:1658
#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:1825
msgid "5 --- are within"
msgstr "5 --- sono all'interno"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:1659
#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:1826
msgid "6 --- cross"
msgstr "6 --- intersecano"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:1661
#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:1828
msgid ""
"If more than one condition is chosen, at least one of them (OR operation) "
"has to be met for a feature to be extracted."
msgstr ""
"Se viene scelta più di una condizione, almeno una di esse (operazione OR) "
