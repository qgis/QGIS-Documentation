msgstr "Zelfdoorsnijdend vs zelfcontact."

#: ../../docs/user_manual/processing_algs/qgis/checkgeometry.rst:1537
msgid ":ref:`qgischeckgeometryselfintersection`"
msgstr ":ref:`qgischeckgeometryselfintersection`"

