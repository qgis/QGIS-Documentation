msgstr ""
"``gc_partidx``: de index van het deel van de geometrie van het object dat de"
" kleine hoek bevat."

#: ../../docs/user_manual/processing_algs/qgis/checkgeometry.rst:2030
msgid ""
"``gc_ringidx``: the index of the feature's geometry ring containing the "
"small angle."
msgstr ""
"``gc_ringidx``: de index van de ring van de geometrie van het object dat de "
"kleine hoek bevat."

#: ../../docs/user_manual/processing_algs/qgis/checkgeometry.rst:2031
