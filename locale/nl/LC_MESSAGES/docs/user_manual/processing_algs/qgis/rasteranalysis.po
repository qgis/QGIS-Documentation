msgstr "1 --- Afgerond naar dichtstbijzijnde"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:4053
msgid "2 --- Round down"
msgstr "2 --- Afgerond naar beneden"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:4054
