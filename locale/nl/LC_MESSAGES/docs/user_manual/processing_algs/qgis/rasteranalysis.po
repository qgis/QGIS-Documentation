#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:2278
msgid "``NODATA_AS_FALSE``"
msgstr "``NODATA_AS_FALSE``"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:2112
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:2282
msgid ""
"Treat NoData values in the input files as 0 when performing the operation"
msgstr ""
"Waarden Geen gegevens in de invoerbestanden behandelen als 0 bij het "
"uitvoeren van de bewerking"

