msgstr "**Waarde rasterband**"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:432
msgid "``VALUE_RASTER_BAND``"
msgstr "``VALUE_RASTER_BAND``"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:435
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3167
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3664
