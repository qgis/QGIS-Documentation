msgid "The layer to rank the values among the stack of all overlaid layers"
msgstr ""
"De laag waarvan de rand van de waarden moet worden bepaald uit de stapel met"
" alle overgelegde lagen"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:23
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:435
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:792
msgid "**Value raster band**"
msgstr "**Waarde rasterband**"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:436
msgid "``VALUE_RASTER_BAND``"
msgstr "``VALUE_RASTER_BAND``"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:439
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3231
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3746
#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:4042
