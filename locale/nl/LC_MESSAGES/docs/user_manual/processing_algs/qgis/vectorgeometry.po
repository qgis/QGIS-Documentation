msgstr "[numeriek: integer] |dataDefine|"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:3733
msgid ""
"Number of parts to keep. If 1, only the biggest part of the feature will be "
"kept."
msgstr ""
"Aantal te behouden delen. Indien 1 wordt alleen het grootste deel van het "
"object behouden."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:3735
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:3758
msgid "**Parts**"
msgstr "**Delen**"

