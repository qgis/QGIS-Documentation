msgstr "**Veld van segment 2**"

#: ../../docs/user_manual/processing_algs/qgis/fixgeometry.rst:1417
msgid "``SEGMENT_2``"
msgstr "``SEGMENT_2``"

#: ../../docs/user_manual/processing_algs/qgis/fixgeometry.rst:1420
msgid "Default: ``gc_segment_2``"
msgstr "Standaard: ``gc_segment_2``"

