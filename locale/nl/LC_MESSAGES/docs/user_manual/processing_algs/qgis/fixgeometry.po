#: ../../docs/user_manual/processing_algs/qgis/fixgeometry.rst:1487
msgid ""
"``gc_partidx``: the index of the feature's geometry part where the self-"
"intersection occurs."
msgstr ""
"``gc_partidx``: de index van het deel van de geometrie van het object waar "
"het zelf doorsnijden optreedt."

#: ../../docs/user_manual/processing_algs/qgis/fixgeometry.rst:1488
msgid ""
"``gc_ringidx``: the index of the feature's geometry ring where the self-"
"intersection occurs."
msgstr ""
"``gc_ringidx``: de index van de ring van de geometrie van het object waar "
"het zelf doorsnijden optreedt."

#: ../../docs/user_manual/processing_algs/qgis/fixgeometry.rst:1490
msgid "``gc_errorx``: the x coordinate of the self-intersection."
msgstr "``gc_errorx``: de X-coördinaat van het zelf doorsnijden."

#: ../../docs/user_manual/processing_algs/qgis/fixgeometry.rst:1491
msgid "``gc_errory``: the y coordinate of the self-intersection."
msgstr "``gc_errory``: de Y-coördinaat van het zelf doorsnijden."

#: ../../docs/user_manual/processing_algs/qgis/fixgeometry.rst:1493
msgid ""
"``gc_segment_1``: the index of the first segment involved in the "
"intersection."
msgstr ""
"``gc_segment_1``: de index van het eerste segment dat is betrokken bij het "
"zelfdoorsnijden."

#: ../../docs/user_manual/processing_algs/qgis/fixgeometry.rst:1494
msgid ""
"``gc_segment_2``: the index of the second segment involved in the "
"intersection."
msgstr ""
"``gc_segment_2``: de index van het tweede segment dat is betrokken bij het "
"zelfdoorsnijden."

