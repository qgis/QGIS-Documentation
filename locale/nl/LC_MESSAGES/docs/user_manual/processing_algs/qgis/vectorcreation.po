msgstr ""
"Het aantal punten dat niet kon worden gemaakt vanwege de beperking van de "
"minimale afstand."

#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1480
#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1752
msgid "**Number of features with missed points**"
msgstr "**Aantal objecten met ontbrekende punten**"

#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1481
msgid "``POLYGONS_WITH_MISSED_POINTS``"
msgstr "``POLYGONS_WITH_MISSED_POINTS``"

#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1483
#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1755
msgid "Not including features with empty or no geometry"
msgstr "Niet inclusief objecten met lege of geen geometrie"

