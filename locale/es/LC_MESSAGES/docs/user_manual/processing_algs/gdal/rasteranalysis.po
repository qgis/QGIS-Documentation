#: ../../docs/user_manual/processing_algs/gdal/rasteranalysis.rst:1618
msgid ""
"Select how far from black, white or custom colors the pixel values can be "
"and still considered near black, white or custom color."
msgstr ""
"Seleccione como de lejos de los colores negro, blanco o personalizados "
"pueden estar los valores de píxeles que aún se consideran cercanos al negro,"
" blanco o color personalizado."

#: ../../docs/user_manual/processing_algs/gdal/rasteranalysis.rst:1621
msgid "**Search for nearly white pixels instead of nearly black**"
msgstr "**Buscar pixeles blancos cercanos en lugar de negros cercanos**"

#: ../../docs/user_manual/processing_algs/gdal/rasteranalysis.rst:1622
msgid "``WHITE``"
msgstr "``WHITE``"

#: ../../docs/user_manual/processing_algs/gdal/rasteranalysis.rst:1626
msgid "Search for nearly white (255) pixels instead of nearly black pixels"
msgstr ""
"Buscar pixeles blancos cercanos (255) en lugar de pixeles negros cercanos"

#: ../../docs/user_manual/processing_algs/gdal/rasteranalysis.rst:1628
#: ../../docs/user_manual/processing_algs/gdal/rasteranalysis.rst:1687
msgid "**Nearblack**"
msgstr "**NegroCercano**"

