msgstr "``CHAR``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:2622
msgid "Character to use for splitting"
msgstr "Carácter a usar para dividir"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:2623
msgid "**Use regular expression separator**"
msgstr "**Usar separador de expresión regular**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:2624
msgid "``REGEX``"
msgstr "``REGEX``"

