msgstr ""
"2 --- Añadir objetos espaciales a la capa existente, pero no crear nuevos "
"campos"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeneral.rst:2482
msgid ""
"3 --- Append features to existing layer, and create new fields if needed"
msgstr ""
"3 --- Añadir objetos espaciales a la capa existente y crear nuevos campos si"
" es necesario"

