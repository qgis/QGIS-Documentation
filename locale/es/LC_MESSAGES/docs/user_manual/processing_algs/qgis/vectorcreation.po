"If checked, the first and last points of the line will be connected and "
"close the generated path"
msgstr ""
"Si está marcado, se conectarán el primer y el último punto de la línea y se "
"cerrará el trayecto generado"

#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:937
msgid "**Order expression**"
msgstr "**Expresión de orden**"

#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:940
msgid "``ORDER_EXPRESSION``"
msgstr "``ORDER_EXPRESSION``"

