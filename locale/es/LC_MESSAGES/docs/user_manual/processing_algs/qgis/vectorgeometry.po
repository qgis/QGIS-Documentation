"Generates a polygon layer using as polygon rings the lines from an input "
"line layer."
msgstr ""
"Genera una capa poligonal usando como anillos poligonales las líneas desde "
"una capa lineal de entrada."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:3777
msgid ""
":ref:`qgispolygonstolines`, :ref:`qgispolygonize`, "
":ref:`qgisconvertgeometrytype`"
msgstr ""
":referencia:`qgispolygonstolines`, :referencia:`qgispolygonize`, "
":referencia:`qgisconvertgeometrytype`"

