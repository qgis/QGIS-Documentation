"Calculates the minimum area rotated rectangle for each feature in the input "
"layer."
msgstr ""
"Calcula el rectángulo rotado de área mínima para cada entidad de la capa "
"entrante."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:4431
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:4454
msgid "**Bounding boxes**"
msgstr "**Cajas frontera**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:4457
msgid ""
