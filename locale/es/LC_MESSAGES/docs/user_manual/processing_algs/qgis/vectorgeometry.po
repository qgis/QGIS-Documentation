msgstr ""
"Especifique la capa vectorial de salida (con los valores M actualizados). "
":ref:`Una de <output_parameter_widget>`:"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6069
msgid "The output vector layer (with updated M values)"
msgstr "La capa vectorial saliente (con valores M actualizados)"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6074
