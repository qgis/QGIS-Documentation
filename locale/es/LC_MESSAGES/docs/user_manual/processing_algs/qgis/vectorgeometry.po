msgstr "[vector: line or polygon]"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1482
msgid "**Maximum distance tolerance**"
msgstr "**Tolerancia de distancia máxima**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1486
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1493
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:5459
msgid "Default: 0.000001"
msgstr "Preestablecido: 0.000001"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1487
msgid ""
"The maximum distance allowed between the original location of vertices and "
"where they would fall on the converted curved geometries"
msgstr ""
"La distancia máxima permitida entre la ubicación original de los vértices y "
"donde caerían en las geometrías curvas convertidas"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1489
msgid "**Maximum angle tolerance**"
msgstr "**Tolerancia de ángulo máxima**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:1490
