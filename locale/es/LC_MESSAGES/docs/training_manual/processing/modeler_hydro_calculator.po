msgid "todo: Add image"
msgstr "todo: Agregar imagen"

#: ../../docs/training_manual/processing/modeler_hydro_calculator.rst:48
msgid "Our new model is now finished."
msgstr "Nuestro nuevo modelo ahora esta finalizado."
