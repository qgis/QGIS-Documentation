msgstr "WMS"

#: ../../docs/server_manual/config.rst:87
msgid "QGIS_SERVER_API_RESOURCES_DIRECTORY"
msgstr "QGIS_SERVER_API_RESOURCES_DIRECTORY"

#: ../../docs/server_manual/config.rst:87
msgid ""
"Base directory for all OGC API (such as OAPIF/WFS3) static resources (HTML "
"templates, CSS, JS, ...)"
msgstr ""
"Bazni direktorijum za sve statičke resurse OGC API-ja (kao što je "
"OAPIF/WFS3) (HTML šabloni, CSS, JS, ...)"

#: ../../docs/server_manual/config.rst:89
msgid "depends on packaging"
msgstr "zavisi od pakovanja"

#: ../../docs/server_manual/config.rst:90
#: ../../docs/server_manual/config.rst:101
msgid "OAPIF/WFS3"
msgstr "OAPIF/WFS3"

#: ../../docs/server_manual/config.rst:93
msgid "QGIS_SERVER_APPLICATION_NAME"
msgstr "QGIS_SERVER_APPLICATION_NAME"

#: ../../docs/server_manual/config.rst:93
msgid ""
"Name of the application to be used, for instance when connecting to a "
"database to identify the QGIS server instance connected"
msgstr ""
"Naziv aplikacije koji se koristi, na primer pri povezivanju sa bazom "
"podataka radi identifikacije povezane instance QGIS server-a"

#: ../../docs/server_manual/config.rst:95
msgid "QGIS3 server"
msgstr "QGIS3 server"

#: ../../docs/server_manual/config.rst:98
msgid "QGIS_SERVER_API_WFS3_MAX_LIMIT"
msgstr "QGIS_SERVER_API_WFS3_MAX_LIMIT"

#: ../../docs/server_manual/config.rst:99
msgid "Maximum value for ``limit`` in a OAPIF/WFS3 features request."
msgstr "Maksimalna vrednost za ``limit`` u OAPIF/WFS3 zahtevu za objektima."

#: ../../docs/server_manual/config.rst:100
msgid "10000"
msgstr "10000"

#: ../../docs/server_manual/config.rst:103
msgid "QGIS_SERVER_CACHE_DIRECTORY"
msgstr "QGIS_SERVER_CACHE_DIRECTORY"

#: ../../docs/server_manual/config.rst:104
msgid "Specifies the network cache directory on the filesystem."
msgstr "Zadaje direktorijum mrežne keš memorije u sistemu datoteka."

#: ../../docs/server_manual/config.rst:105
msgid "``cache`` in profile directory"
msgstr "``cache`` u direktorijumu profila"

#: ../../docs/server_manual/config.rst:108
msgid "QGIS_SERVER_CACHE_SIZE"
msgstr "QGIS_SERVER_CACHE_SIZE"

#: ../../docs/server_manual/config.rst:109
msgid "Sets the network cache size in bytes."
msgstr "Postavlja veličinu mrežne keš memorije u bajtovima."

#: ../../docs/server_manual/config.rst:110
msgid "50 MB"
msgstr "50 MB"

#: ../../docs/server_manual/config.rst:113
msgid "QGIS_SERVER_CAPABILITIES_CACHE_SIZE"
msgstr "QGIS_SERVER_CAPABILITIES_CACHE_SIZE"

#: ../../docs/server_manual/config.rst:114
msgid "The maximum number of project capabilities to cache."
msgstr "Maksimalan broj mogućnosti projekta koje se keširaju."

#: ../../docs/server_manual/config.rst:115
msgid "40"
msgstr "40"

#: ../../docs/server_manual/config.rst:122
msgid "QGIS_SERVER_DISABLE_GETPRINT"
msgstr "QGIS_SERVER_DISABLE_GETPRINT"

#: ../../docs/server_manual/config.rst:119
msgid ""
"This is an option at the project level to improve project read time by "
"disabling loading of layouts."
msgstr ""
"Ovo je opcija na nivou projekta za poboljšanje vremena čitanja projekta "
"onemogućavanjem učitavanja rasporeda."

#: ../../docs/server_manual/config.rst:122
msgid ""
"Activating this option disables the QGIS WMS GetPrint request. Set this QGIS"
" project flag to not load layouts."
msgstr ""
"Aktiviranje ove opcije onemogućava QGIS WMS GetPrint zahtev. Postavite ovu "
"zastavicu QGIS projekta da se rasporedi ne učitavaju."

#: ../../docs/server_manual/config.rst:124
#: ../../docs/server_manual/config.rst:129
#: ../../docs/server_manual/config.rst:139
#: ../../docs/server_manual/config.rst:189
#: ../../docs/server_manual/config.rst:199
#: ../../docs/server_manual/config.rst:221
#: ../../docs/server_manual/config.rst:275
#: ../../docs/server_manual/config.rst:289
msgid "false"
msgstr "false"

#: ../../docs/server_manual/config.rst:127
msgid "QGIS_SERVER_FORCE_READONLY_LAYERS"
msgstr "QGIS_SERVER_FORCE_READONLY_LAYERS"

#: ../../docs/server_manual/config.rst:128
msgid "Force QGIS Server to open all layers in a read only mode"
msgstr "Prisiljava QGIS Server da otvori sve slojeve u režimu samo za čitanje"

#: ../../docs/server_manual/config.rst:137
msgid "QGIS_SERVER_IGNORE_BAD_LAYERS"
msgstr "QGIS_SERVER_IGNORE_BAD_LAYERS"

#: ../../docs/server_manual/config.rst:133
msgid ""
"\"Bad\" layers are layers that cannot be loaded. The default behavior of "
"QGIS Server is to consider the project as not available if it contains a bad"
" layer."
msgstr ""
"„Loši“ slojevi su slojevi koji se ne mogu učitati. Podrazumevano ponašanje "
"QGIS Server-a je da projekat smatra nedostupnim ako sadrži loš sloj."

#: ../../docs/server_manual/config.rst:136
msgid ""
"The default behavior can be overridden by setting this variable to ``1`` or "
"``true``. In this case, \"bad\" layers will just be ignored, and the project"
" will be considered valid and available."
msgstr ""
"Podrazumevano ponašanje može se zameniti postavljanjem ove promenljive na "
"``1`` ili ``true``. U tom slučaju, „loši“ slojevi će jednostavno biti "
"zanemareni, a projekat će se smatrati ispravnim i dostupnim."

#: ../../docs/server_manual/config.rst:142
msgid "QGIS_SERVER_LANDING_PAGE_PREFIX"
msgstr "QGIS_SERVER_LANDING_PAGE_PREFIX"

#: ../../docs/server_manual/config.rst:143
msgid "Prefix of the path component of the landing page base URL"
msgstr "Prefiks komponente putanje bazne URL adrese odredišne stranice"

#: ../../docs/server_manual/config.rst:144
#: ../../docs/server_manual/config.rst:151
#: ../../docs/server_manual/config.rst:158
msgid "\"\""
msgstr "\"\""

#: ../../docs/server_manual/config.rst:149
msgid "QGIS_SERVER_LANDING_PAGE_PROJECTS_DIRECTORIES"
msgstr "QGIS_SERVER_LANDING_PAGE_PROJECTS_DIRECTORIES"

#: ../../docs/server_manual/config.rst:150
msgid ""
"Directories used by the landing page service to find .qgs and .qgz projects"
msgstr ""
"Direktorijumi koje servis odredišne stranice koristi za pronalaženje .qgs i "
".qgz projekata"

#: ../../docs/server_manual/config.rst:156
msgid "QGIS_SERVER_LANDING_PAGE_PROJECTS_PG_CONNECTIONS"
msgstr "QGIS_SERVER_LANDING_PAGE_PROJECTS_PG_CONNECTIONS"

#: ../../docs/server_manual/config.rst:157
msgid ""
"PostgreSQL connection strings used by the landing page service to find "
"projects"
msgstr ""
"PostgreSQL niske za povezivanje koje servis odredišne stranice koristi za "
"pronalaženje projekata"

#: ../../docs/server_manual/config.rst:169
msgid "QGIS_SERVER_LOG_FILE"
msgstr "QGIS_SERVER_LOG_FILE"

#: ../../docs/server_manual/config.rst:164
msgid ""
"Specify path and filename. Make sure that server has proper permissions for "
"writing to file. File should be created automatically, just send some "
"requests to server. If it's not there, check permissions."
msgstr ""
"Zadajte putanju i naziv datoteke. Uverite se da server ima odgovarajuće "
"dozvole za upisivanje u datoteku. Datoteka bi trebalo da se napravi "
"automatski, samo pošaljite neke zahteve serveru. Ako je nema, proverite "
"dozvole."

#: ../../docs/server_manual/config.rst:168
msgid ""
"QGIS_SERVER_LOG_FILE is deprecated since QGIS 3.4, use "
"QGIS_SERVER_LOG_STDERR instead. File logging support will be removed in QGIS"
" 5.0."
msgstr ""
"QGIS_SERVER_LOG_FILE je zastareo od QGIS 3.4, umesto njega koristite "
"QGIS_SERVER_LOG_STDERR. Podrška za beleženje u datoteku biće uklonjena u "
"QGIS 5.0."

#: ../../docs/server_manual/config.rst:180
msgid "QGIS_SERVER_LOG_LEVEL"
msgstr "QGIS_SERVER_LOG_LEVEL"

#: ../../docs/server_manual/config.rst:177
msgid "Specify desired log level. Available values are:"
msgstr "Zadajte željeni nivo dnevnika. Dostupne vrednosti su:"

#: ../../docs/server_manual/config.rst:179
msgid "``0`` or ``INFO`` (log all requests)"
msgstr "``0`` ili ``INFO`` (beleži sve zahteve)"

#: ../../docs/server_manual/config.rst:180
msgid "``1`` or ``WARNING``"
msgstr "``1`` ili ``WARNING``"

#: ../../docs/server_manual/config.rst:181
msgid ""
"``2`` or ``CRITICAL`` (log just critical errors, suitable for production "
"purposes)"
msgstr ""
"``2`` ili ``CRITICAL`` (beleži samo kritične greške, pogodno za produkcione "
"svrhe)"

#: ../../docs/server_manual/config.rst:182
msgid "0"
msgstr "0"

#: ../../docs/server_manual/config.rst:187
msgid "QGIS_SERVER_LOG_PROFILE"
msgstr "QGIS_SERVER_LOG_PROFILE"

#: ../../docs/server_manual/config.rst:188
msgid ""
"Add detailed profile information to the logs, only effective when "
"QGIS_SERVER_LOG_LEVEL=0"
msgstr ""
"Dodaje detaljne informacije o profilu u dnevnike, deluje samo kada je "
"QGIS_SERVER_LOG_LEVEL=0"

#: ../../docs/server_manual/config.rst:197
msgid "QGIS_SERVER_LOG_STDERR"
msgstr "QGIS_SERVER_LOG_STDERR"

#: ../../docs/server_manual/config.rst:195
msgid ""
"Activate logging to stderr. This variable  has no effect when "
"``QGIS_SERVER_LOG_FILE`` is set."
msgstr ""
"Aktivira beleženje u stderr. Ova promenljiva nema efekta kada je "
"``QGIS_SERVER_LOG_FILE`` postavljena."

#: ../../docs/server_manual/config.rst:197
#: ../../docs/server_manual/config.rst:219
#: ../../docs/server_manual/config.rst:273
msgid "``0`` or ``false`` (case insensitive)"
msgstr "``0`` ili ``false`` (neosetljivo na velika/mala slova)"

#: ../../docs/server_manual/config.rst:198
#: ../../docs/server_manual/config.rst:220
#: ../../docs/server_manual/config.rst:274
msgid "``1`` or ``true`` (case insensitive)"
msgstr "``1`` ili ``true`` (neosetljivo na velika/mala slova)"

#: ../../docs/server_manual/config.rst:203
msgid "QGIS_SERVER_MAX_THREADS"
msgstr "QGIS_SERVER_MAX_THREADS"

#: ../../docs/server_manual/config.rst:203
msgid ""
"Number of threads to use when parallel rendering is activated. If value is "
"``-1`` it uses the number of processor cores."
msgstr ""
"Broj niti koje se koriste kada je aktivirano paralelno iscrtavanje. Ako je "
"vrednost ``-1``, koristi broj procesorskih jezgara."

#: ../../docs/server_manual/config.rst:205
#: ../../docs/server_manual/config.rst:307
#: ../../docs/server_manual/config.rst:313
msgid "-1"
msgstr "-1"

#: ../../docs/server_manual/config.rst:210
msgid "QGIS_SERVER_OVERRIDE_SYSTEM_LOCALE"
msgstr "QGIS_SERVER_OVERRIDE_SYSTEM_LOCALE"

#: ../../docs/server_manual/config.rst:209
msgid ""
"Sets LOCALE to be used by QGIS server. The default value is empty (no "
"override)."
msgstr ""
"Postavlja LOCALE koji QGIS server koristi. Podrazumevana vrednost je prazna "
"(bez zamene)."

#: ../../docs/server_manual/config.rst:211
msgid "Example: ``de_CH.utf8``"
msgstr "Primer: ``de_CH.utf8``"

#: ../../docs/server_manual/config.rst:219
msgid "QGIS_SERVER_PARALLEL_RENDERING"
msgstr "QGIS_SERVER_PARALLEL_RENDERING"

#: ../../docs/server_manual/config.rst:216
msgid ""
"Activates parallel rendering for WMS GetMap requests. It's disabled "
"(``false``) by default. Available values are:"
msgstr ""
"Aktivira paralelno iscrtavanje za WMS GetMap zahteve. Podrazumevano je "
"onemogućeno (``false``). Dostupne vrednosti su:"

#: ../../docs/server_manual/config.rst:225
msgid "QGIS_SERVER_PROJECT_CACHE_CHECK_INTERVAL"
msgstr "QGIS_SERVER_PROJECT_CACHE_CHECK_INTERVAL"

#: ../../docs/server_manual/config.rst:225
msgid ""
"Controls the periodic strategy interval for cache invalidation, in "
"milliseconds. Defaults to 0 which selects the legacy File system watcher."
msgstr ""
"Kontroliše interval periodične strategije za poništavanje keša, u "
"milisekundama. Podrazumevano je 0, što bira nasleđeni nadzornik sistema "
"datoteka."

#: ../../docs/server_manual/config.rst:231
msgid "QGIS_SERVER_PROJECT_CACHE_SIZE"
msgstr "QGIS_SERVER_PROJECT_CACHE_SIZE"

#: ../../docs/server_manual/config.rst:231
msgid ""
"Sets the maximum number of QGIS project files (.qgs/.qgz) to keep in server "
"cache. This can improve performance when serving the same projects "
"repeatedly."
msgstr ""
"Postavlja maksimalan broj datoteka QGIS projekata (.qgs/.qgz) koje se čuvaju"
" u kešu servera. Ovo može poboljšati performanse pri opsluživanju istih "
"projekata više puta."

#: ../../docs/server_manual/config.rst:233
msgid "100"
msgstr "100"

#: ../../docs/server_manual/config.rst:242
msgid "QGIS_SERVER_PROJECT_CACHE_STRATEGY"
msgstr "QGIS_SERVER_PROJECT_CACHE_STRATEGY"

#: ../../docs/server_manual/config.rst:237
msgid ""
"Defines method for invalidating the project cache. Available strategies are:"
msgstr "Definiše metod za poništavanje keša projekta. Dostupne strategije su:"

#: ../../docs/server_manual/config.rst:239
msgid "``filesystem``: uses the file system watcher strategy"
msgstr "``filesystem``: koristi strategiju nadzornika sistema datoteka"

#: ../../docs/server_manual/config.rst:240
msgid ""
"``periodic``: uses the last modified value of a project for checking changes"
" on project configuration. Convenient on atypical file systems, such as NFS,"
" or when the project file is stored in a database system like PostgreSQL."
msgstr ""
"``periodic``: koristi vrednost poslednje izmene projekta za proveru promena "
"u konfiguraciji projekta. Zgodno na atipičnim sistemima datoteka, kao što je"
" NFS, ili kada je datoteka projekta sačuvana u sistemu baze podataka kao što"
" je PostgreSQL."

#: ../../docs/server_manual/config.rst:243
msgid "``off``: disables internal cache invalidation completely"
msgstr "``off``: potpuno onemogućava interno poništavanje keša"

#: ../../docs/server_manual/config.rst:244
msgid "filesystem"
msgstr "filesystem"

#: ../../docs/server_manual/config.rst:264
msgid "QGIS_SERVER_SERVICE_URL"
msgstr "QGIS_SERVER_SERVICE_URL"

#: ../../docs/server_manual/config.rst:250
msgid ""
"This is an option to set the service URL if it is not present in the "
"project."
msgstr ""
"Ovo je opcija za postavljanje URL-a servisa ako nije prisutan u projektu."

#: ../../docs/server_manual/config.rst:252
msgid "The service URL is defined from (in order of precedence):"
msgstr "URL servisa se definiše iz (po redosledu prioriteta):"

#: ../../docs/server_manual/config.rst:254
msgid "Value defined in the project per service"
msgstr "Vrednost definisana u projektu po servisu"

#: ../../docs/server_manual/config.rst:255
msgid "The ``QGIS_SERVER_<service>_SERVICE_URL`` environment variable"
msgstr "Promenljiva okruženja ``QGIS_SERVER_<service>_SERVICE_URL``"

#: ../../docs/server_manual/config.rst:256
msgid "The ``QGIS_SERVER_SERVICE_URL`` environment variable"
msgstr "Promenljiva okruženja ``QGIS_SERVER_SERVICE_URL``"

