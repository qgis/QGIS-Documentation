msgstr "Izgradnja iz zaglavlja ``Forwarded``"

#: ../../docs/server_manual/config.rst:260
msgid "Build from the ``X-Forwarded-Host`` and ``X-Forwarded-Proto`` headers"
msgstr "Izgradnja iz zaglavlja ``X-Forwarded-Host`` i ``X-Forwarded-Proto``"

#: ../../docs/server_manual/config.rst:261
msgid "Build from the ``Host`` header and the server protocol"
msgstr "Izgradnja iz zaglavlja ``Host`` i protokola servera"

#: ../../docs/server_manual/config.rst:262
