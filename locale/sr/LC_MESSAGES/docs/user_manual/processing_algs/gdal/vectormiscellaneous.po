msgid "``CLIP``"
msgstr "``CLIP``"

#: ../../docs/user_manual/processing_algs/gdal/vectormiscellaneous.rst:386
#: ../../docs/user_manual/processing_algs/gdal/vectormiscellaneous.rst:721
msgid "The input layer will be clipped by the extent you defined before"
msgstr "Ulazni sloj biće isečen obuhvatom koji ste prethodno definisali"

