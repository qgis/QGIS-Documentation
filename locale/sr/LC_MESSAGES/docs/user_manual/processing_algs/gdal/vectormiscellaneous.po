#: ../../docs/user_manual/processing_algs/gdal/vectormiscellaneous.rst:818
msgid "Avoids modifying column attributes to comply with input data"
msgstr "Izbegava izmenu atributa kolona radi usklađivanja sa ulaznim podacima"

#: ../../docs/user_manual/processing_algs/gdal/vectormiscellaneous.rst:487
#: ../../docs/user_manual/processing_algs/gdal/vectormiscellaneous.rst:831
