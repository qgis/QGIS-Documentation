msgstr "``SKIPFAILURES``"

#: ../../docs/user_manual/processing_algs/gdal/vectormiscellaneous.rst:455
#: ../../docs/user_manual/processing_algs/gdal/vectormiscellaneous.rst:799
msgid "Continue after a failure, skipping the failed feature."
msgstr "Nastavi nakon greške, preskačući objekat sa greškom."

#: ../../docs/user_manual/processing_algs/gdal/vectormiscellaneous.rst:456
#: ../../docs/user_manual/processing_algs/gdal/vectormiscellaneous.rst:800
msgid "**Validate geometries based on Simple Features specification**"
msgstr "**Proveri ispravnost geometrija prema specifikaciji Simple Features**"

