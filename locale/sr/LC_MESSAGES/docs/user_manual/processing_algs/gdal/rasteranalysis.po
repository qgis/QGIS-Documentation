msgstr "Kanal koji sadrži informaciju o visini"

#: ../../docs/user_manual/processing_algs/gdal/rasteranalysis.rst:1448
msgid "**Z factor (vertical exaggeration)**"
msgstr "**Z faktor (vertikalno preuveličavanje)**"

#: ../../docs/user_manual/processing_algs/gdal/rasteranalysis.rst:1449
