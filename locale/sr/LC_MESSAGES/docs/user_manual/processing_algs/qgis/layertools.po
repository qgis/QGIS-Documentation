#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:147
msgid "[file]"
msgstr "[datoteka]"

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:126
msgid "Default: ``[Save to temporary file]``"
msgstr "Podrazumevano: ``[Save to temporary file]``"

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:127
msgid ""
"Output spreadsheet with a sheet for every layer. :ref:`One of "
"<output_parameter_widget>`:"
msgstr ""
"Izlazni tabelarni dokument sa listom za svaki sloj. :ref:`Jedno od "
"<output_parameter_widget>`:"

#: ../../docs/user_manual/processing_algs/algs_include.rst:3
msgid "Save to a Temporary File"
msgstr "Sačuvaj u privremenu datoteku"

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:148
msgid "Spreadsheet with a sheet for every layer."
msgstr "Tabelarni dokument sa listom za svaki sloj."

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:149
msgid "**Layers within spreadsheet**"
msgstr "**Slojevi unutar tabelarnog dokumenta**"

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:150
msgid "``OUTPUT_LAYERS``"
msgstr "``OUTPUT_LAYERS``"

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:151
msgid "[list]"
msgstr "[lista]"

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:152
msgid "The list of sheets added to the spreadsheet."
msgstr "Lista listova dodatih u tabelarni dokument."

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:157
msgid "**Algorithm ID**: ``native:exporttospreadsheet``"
msgstr "**ID algoritma**: ``native:exporttospreadsheet``"

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:167
msgid "Extract layer extent"
msgstr "Izdvajanje obuhvata sloja"

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:169
msgid ""
"Generates a vector layer with the minimum bounding box (rectangle with N-S "
"orientation) that covers all the input features."
msgstr ""
"Generiše vektorski sloj sa najmanjim graničnim pravougaonikom (pravougaonik "
"sa orijentacijom S-J) koji pokriva sve ulazne objekte."

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:172
msgid ""
"The output layer contains a single bounding box for the whole input layer."
msgstr "Izlazni sloj sadrži jedan granični pravougaonik za ceo ulazni sloj."

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:177
msgid "In red the bounding box of the source layer"
msgstr "Crveno je granični pravougaonik izvornog sloja"

#: ../../docs/user_manual/processing_algs/qgis/layertools.rst:179
