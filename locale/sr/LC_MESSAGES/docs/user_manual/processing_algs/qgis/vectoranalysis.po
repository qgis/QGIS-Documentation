msgstr "Metod izračunavanja najkraćeg rastojanja. Moguće vrednosti su:"

#: ../../docs/user_manual/processing_algs/qgis/vectoranalysis.rst:1524
msgid "0 --- Distance to nearest point on feature"
msgstr "0 --- Rastojanje do najbliže tačke na objektu"

#: ../../docs/user_manual/processing_algs/qgis/vectoranalysis.rst:1525
msgid "1 --- Distance to feature centroid"
msgstr "1 --- Rastojanje do centroida objekta"

#: ../../docs/user_manual/processing_algs/qgis/vectoranalysis.rst:1527
msgid "**Maximum number of neighbors**"
msgstr "**Najveći broj suseda**"

#: ../../docs/user_manual/processing_algs/qgis/vectoranalysis.rst:1528
msgid "``NEIGHBORS``"
msgstr "``NEIGHBORS``"

#: ../../docs/user_manual/processing_algs/qgis/vectoranalysis.rst:1531
msgid "Default: 1"
msgstr "Podrazumevano: 1"

#: ../../docs/user_manual/processing_algs/qgis/vectoranalysis.rst:1532
