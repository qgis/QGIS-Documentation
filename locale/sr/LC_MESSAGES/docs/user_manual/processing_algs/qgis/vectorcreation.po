#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1107
#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1220
#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1301
#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1466
#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1582
