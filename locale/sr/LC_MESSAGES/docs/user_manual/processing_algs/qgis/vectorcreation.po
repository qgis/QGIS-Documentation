#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:729
#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1049
#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1245
#: ../../docs/user_manual/processing_algs/qgis/vectorcreation.rst:1513
msgid ""
"This algorithm drops existing primary keys or FID values and regenerates "
"them in output layers."
msgstr ""
"Ovaj algoritam uklanja postojeće primarne ključeve ili FID vrednosti i "
"ponovo ih generiše u izlaznim slojevima."

