msgid "**New NoData value**"
msgstr "**Nova NoData vrednost**"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3920
msgid "``NODATA``"
msgstr "``NODATA``"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3923
