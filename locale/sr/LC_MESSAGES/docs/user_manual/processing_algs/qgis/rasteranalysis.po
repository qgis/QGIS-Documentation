msgid "1 --- Round to nearest"
msgstr "1 --- Zaokruži na najbliže"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:4053
msgid "2 --- Round down"
msgstr "2 --- Zaokruži naniže"

