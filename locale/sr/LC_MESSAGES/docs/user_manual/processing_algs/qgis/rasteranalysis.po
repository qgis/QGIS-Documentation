msgstr "Broj: broj piksela u zoni;"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3181
msgid "Min: the minimum pixel value in the zone;"
msgstr "Min: minimalna vrednost piksela u zoni;"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3182
msgid "Max: the maximum pixel value in the zone;"
msgstr "Max: maksimalna vrednost piksela u zoni;"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3183
msgid "Mean: the mean of the pixel values in the zone;"
msgstr "Mean: srednja vrednost vrednosti piksela u zoni;"

