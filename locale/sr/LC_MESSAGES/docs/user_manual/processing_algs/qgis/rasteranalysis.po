msgstr "Podrazumevano: 0 (Minimum i maksimum)"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3238
msgid "Choose which extrema to extract:"
msgstr "Izaberite koje ekstremne vrednosti da izdvojite:"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3240
msgid "0: Minimum and Maximum"
msgstr "0: Minimum i maksimum"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3241
msgid "1: Minimum only"
msgstr "1: Samo minimum"

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3242
msgid "2: Maximum only"
msgstr "2: Samo maksimum"

