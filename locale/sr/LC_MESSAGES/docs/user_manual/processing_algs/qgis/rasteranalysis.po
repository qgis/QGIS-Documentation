msgid "If the raster is multiband, choose a band."
msgstr "Ako je raster višekanalni, izaberite kanal."

#: ../../docs/user_manual/processing_algs/qgis/rasteranalysis.rst:3905
msgid "**New minimum value**"
msgstr "**Nova minimalna vrednost**"

