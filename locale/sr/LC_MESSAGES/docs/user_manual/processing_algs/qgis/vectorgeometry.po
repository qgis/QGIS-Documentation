msgstr "``NODATA``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2273
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6126
msgid ""
"Value to use in case the vertex does not intersect (a valid pixel of) the "
"raster"
msgstr ""
"Vrednost koja se koristi u slučaju da teme ne preseca (validan piksel) "
"rastera"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2275
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6128
msgid "**Scale factor**"
msgstr "**Faktor skaliranja**"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2276
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6129
msgid "``SCALE``"
msgstr "``SCALE``"

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2280
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:6133
msgid "Scaling value: the band values are multiplied by this value."
msgstr "Vrednost skaliranja: vrednosti kanala se množe ovom vrednošću."

#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:2282
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:4454
#: ../../docs/user_manual/processing_algs/qgis/vectorgeometry.rst:4478
